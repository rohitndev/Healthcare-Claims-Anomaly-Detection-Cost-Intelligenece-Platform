# Copy this file to `.env` and fill in values to enable optional cloud services.
# Every variable is OPTIONAL — with none set, the pipeline runs fully on the local
# filesystem with deterministic fallbacks.

# ---- Execution engine ----
# Set to true to use PySpark (requires pyspark installed + working Spark env).
USE_SPARK=false
# Set to true to use Microsoft Presidio for PHI scrubbing (else regex fallback).
USE_PRESIDIO=true
# Set to true to use ClinicalBERT (requires torch + transformers); else lexical aligner.
USE_CLINICALBERT=false

# ---- Synthetic data volume ----
N_CLAIMS=5000
N_PROVIDERS=120

# ---- AWS S3 (HIPAA-compliant claims data lake) ----
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ---- AWS SNS (high-risk claim alerts) ----
AWS_SNS_TOPIC_ARN=

# ---- Snowflake (fraud scores / audit reports / compliance history) ----
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=CLAIMS_INTELLIGENCE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ---- Groq API (Mixtral 8x7B clinical audit narratives) ----
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# ---- ClinicalBERT weights ----
CLINICALBERT_MODEL=emilyalsentzer/Bio_ClinicalBERT
